{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8180/realms/ems",
    "Audience": "ems-api",
    "RequireHttpsMetadata": false
  },
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    }
  },
  "ConnectionStrings": {
    "PostgresQL": "Host=localhost;Port=5432;Database=UserProfile;Username=postgres;Password=;"
  },
  "FileStorage": {
    "BasePath": "/app/uploads",
    "BaseUrl": "/uploads"
  }
}
