{
  "realm": "ems",
  "enabled": true,
  "loginTheme": "ems",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "System administrator with full access"
      },
      {
        "name": "organizer",
        "description": "Event organizer who can create and manage their own events"
      },
      {
        "name": "user",
        "description": "Regular user who can browse events, comment, and subscribe"
      }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "ems-api",
      "name": "EMS API Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "ems-api-secret",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:*",
        "http://host.docker.internal:*"
      ],
      "webOrigins": [
        "http://localhost:5000",
        "http://localhost:8080",
        "http://host.docker.internal:*"
      ],
      "defaultClientScopes": [
        "basic",
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "ems-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "ems-spa",
      "name": "EMS SPA/Mobile Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "redirectUris": [
        "http://localhost:*",
        "http://host.docker.internal:*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5000",
        "http://localhost:10000",
        "http://host.docker.internal:3000"
      ],
      "defaultClientScopes": [
        "basic",
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "ems-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "ems-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin-user",
      "enabled": true,
      "email": "admin@ems.local",
      "firstName": "Admin",
      "lastName": "User",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "user"]
    },
    {
      "username": "organizer-user",
      "enabled": true,
      "email": "organizer@ems.local",
      "firstName": "Organizer",
      "lastName": "User",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": ["organizer", "user"]
    },
    {
      "username": "test-user",
      "enabled": true,
      "email": "test@ems.local",
      "firstName": "Test",
      "lastName": "User",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    }
  ]
}
