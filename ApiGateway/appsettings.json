{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel":{
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8180/realms/ems",
    "Audience": "ems-api",
    "RequireHttpsMetadata": false
  },
  "ReverseProxy":{
    "Routes":{
      "events-route":{
        "ClusterId":"events-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "frontend",
        "Match":{
          "Path": "api/events/{**catch-all}"
        }
      },
      "event-uploads":{
        "ClusterId": "events-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": { "Path": "/uploads/events/{**catch-all}"}
      },
      "users-route":{
        "ClusterId":"users-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match":{
          "Path": "api/users/{**catch-all}"
        }
      },
      "user-uploads":{
        "ClusterId": "users-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": { "Path": "/uploads/users/{**catch-all}"}
      },
      "venue-route":{
        "ClusterId":"venue-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match":{
          "Path": "api/venues/{**catch-all}"
        }
      },
      "aggregator-route":{
        "ClusterId":"aggregator-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "frontend",
        "Match":{
          "Path": "api/aggregator/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/aggregator" },
          { "PathPrefix": "/api/aggregated" }
        ]
      }
    },
    "Clusters":{
      "events-cluster": {
        "HttpRequest": {
          "Version": "1.1",
          "VersionPolicy": "RequestVersionExact"
        },
        "Destinations": {
          "EventCatalogService": {
            "Address": "http://EventCatalogService"
          }
        }
      },
      "users-cluster":{
        "HttpRequest": {
          "Version": "1.1",
          "VersionPolicy": "RequestVersionExact"
        },
        "Destinations": {
          "UserProfileService": {
            "Address": "http://UserProfileService"
          }
        }
      },
      "venue-cluster":{
        "HttpRequest": {
          "Version": "1.1",
          "VersionPolicy": "RequestVersionExact"
        },
        "Destinations": {
          "VenueService": {
            "Address": "http://VenueService"
          }
        }
      },
      "aggregator-cluster":{
        "HttpRequest": {
          "Version": "1.1",
          "VersionPolicy": "RequestVersionExact"
        },
        "Destinations":{
          "Aggregator":{
            "Address": "http://Aggregator"
          }
        }
      }
    }
  }
}
