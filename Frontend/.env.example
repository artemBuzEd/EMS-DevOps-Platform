# Base URL of the API Gateway (YARP). The browser calls this directly (CORS enabled on the gateway).
NEXT_PUBLIC_API_BASE_URL=http://localhost:10000

# Keycloak (Authorization Code + PKCE via keycloak-js). The browser talks to
# Keycloak directly; tokens are held in memory only.
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8180
NEXT_PUBLIC_KEYCLOAK_REALM=ems
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=ems-spa

# OBSOLETE — removed. The dashboard now authenticates through Keycloak, so the
# old dev-token shortcut is gone. Do NOT reintroduce these:
#   NEXT_PUBLIC_DEV_BEARER_TOKEN
#   NEXT_PUBLIC_DEV_USER_ID
